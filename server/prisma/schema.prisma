generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  passwordHash   String
  plan                 String          @default("free")
  resumeText           String?
  resumeName           String?
  lookupsUsedThisMonth Int             @default(0)
  lookupsResetAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  outreaches     Outreach[]
  trackingPixels TrackingPixel[]
}

model Outreach {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  threadId       String    @unique
  gmailUrl       String
  company        String
  contactName    String
  contactEmail   String
  domain         String
  subject        String
  sentDate       DateTime
  status         String    @default("Sent")
  snippet        String    @default("")
  messageCount   Int       @default(1)
  hasReply       Boolean   @default(false)
  repliedAt      DateTime?
  latestActivity DateTime
  favorite       Boolean   @default(false)
  archived       Boolean   @default(false)
  notes          String    @default("")
  isOpened       Boolean   @default(false)
  openCount      Int       @default(0)
  lastOpenedAt   DateTime?
  nextActionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([sentDate])
  @@index([archived])
}

model TrackingPixel {
  id         String      @id @default(cuid())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  threadId   String
  trackingId String      @unique
  createdAt  DateTime    @default(now())
  openEvents OpenEvent[]
}

model OpenEvent {
  id            String        @id @default(cuid())
  trackingId    String
  openedAt      DateTime      @default(now())
  userAgent     String?
  ipAddress     String?
  trackingPixel TrackingPixel @relation(fields: [trackingId], references: [trackingId], onDelete: Cascade)
}
