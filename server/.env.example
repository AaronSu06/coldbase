# Required — generate with: npm run generate-secret (at repo root)
JWT_SECRET=                        # generate with: npm run generate-secret (at repo root)
BCRYPT_ROUNDS=12                   # lower to 1 for tests (set in test file)

# Gemini AI key
GEMINI_KEY=

# Hunter.io email finder API key — https://hunter.io/api-keys
HUNTER_KEY=

# Comma-separated origins allowed by CORS
# chrome-extension:// origins are always permitted regardless of this list
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection (Neon)
# Pooled connection string (hostname contains -pooler) — used by the app at runtime
DATABASE_URL=

# Direct connection string (no -pooler) — required for prisma migrate / db push
DIRECT_URL=

# Test database (Neon test branch) — used by outreach.test.js, tracking.test.js, analytics.test.js
TEST_DATABASE_URL=

# Direct connection for test branch — required for prisma migrate reset in test setup
TEST_DIRECT_URL=

# Sentry DSN — optional; if absent, error monitoring is disabled (safe for local dev)
# SENTRY_DSN=

# Stripe billing
# Secret key — Stripe Dashboard → Developers → API keys → Secret key (sk_test_... for test mode)
STRIPE_SECRET_KEY=

# Price IDs — Stripe Dashboard → Products → [product] → Prices → copy the price_... ID
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret (whsec_...)
# For local dev: run `stripe listen --forward-to localhost:3001/api/billing/webhook`
# and use the whsec_ secret it prints
STRIPE_WEBHOOK_SECRET=

# Frontend URL — used for Stripe redirect URLs after checkout / portal
CLIENT_URL=http://localhost:5173
