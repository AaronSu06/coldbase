# Required — generate with: npm run generate-secret (at repo root)
REACH_SECRET=

# Gemini AI key
GEMINI_KEY=

# Comma-separated origins allowed by CORS
# chrome-extension:// origins are always permitted regardless of this list
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection (Neon)
# Pooled connection string (hostname contains -pooler) — used by the app at runtime
DATABASE_URL=

# Direct connection string (no -pooler) — required for prisma migrate / db push
DIRECT_URL=

# Test database (Neon test branch) — used by outreach.test.js, tracking.test.js, analytics.test.js
TEST_DATABASE_URL=

# Direct connection for test branch — required for prisma migrate reset in test setup
TEST_DIRECT_URL=
